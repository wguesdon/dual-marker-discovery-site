---
import Base from '../layouts/Base.astro';
const title = 'Ask the data — Dual-marker discovery';
const description = 'TODO: an interactive assistant grounded in the study data. Ask about any marker, any pair, any gate.';
---
<Base title={title} description={description} page="ask">
  <section class="hero" style="padding-bottom:0.6rem">
    <div class="container">
      <p class="eyebrow">The assistant</p>
      <h1>Explore the pairs, and ask about what you see</h1>
      <p class="lede">
        TODO: the pitch. It answers from the study's committed tables using tools over the markers,
        the pairs, and the gate scores. It is powered by Claude and is access-controlled. For the
        full-screen experience, <a href="/app" target="_blank" rel="noopener">open it in a new tab</a>.
      </p>
      <div class="embed-bar">
        <a class="btn primary" href="/app" target="_blank" rel="noopener">Open the assistant in a new tab &rarr;</a>
        <span class="pill">grounded chat · Claude</span>
      </div>
    </div>
  </section>
  <section class="block">
    <div class="container">
      <iframe class="embed" src="/app" title="Explore and ask" loading="lazy" style="height:90vh"></iframe>
    </div>
  </section>
</Base>
