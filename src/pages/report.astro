---
import Base from '../layouts/Base.astro';

const title = 'Report — Dual-marker discovery';
const description =
  'Per-patient discovery of combinatorial cell-surface targets in prostate cancer. Abstract, background, data, methods, results, robustness, and limitations.';
---
<Base title={title} description={description} page="report">
  <section class="hero" style="padding-bottom:0.6rem">
    <div class="container">
      <p class="eyebrow">The science</p>
      <h1>Report</h1>
      <p class="lede">
        Per-patient discovery of combinatorial cell-surface targets in prostate cancer. Abstract,
        background, data, methods, results, robustness, and limitations.
      </p>
      <div class="embed-bar">
        <a class="btn primary" href="/report.html" target="_blank" rel="noopener">Open the report in a new tab &rarr;</a>
        <a class="btn ghost" href="https://github.com/wguesdon/dual-marker-discovery" target="_blank" rel="noopener">Main repository</a>
      </div>
    </div>
  </section>
  <section class="block">
    <div class="container">
      <iframe class="embed" src="/report.html" title="Scientific report" loading="lazy"></iframe>
    </div>
  </section>
</Base>
