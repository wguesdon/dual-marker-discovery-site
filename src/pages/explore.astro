---
import Base from '../layouts/Base.astro';

const title = 'Explore with Claude — Dual-marker discovery';
const description =
  'Colour every tumor cell by which markers it carries, watch the AND gate appear, and ask a grounded Claude assistant about any pair. It answers only from the study\'s committed tables.';
---
<Base title={title} description={description} page="explore">
  <section class="hero" style="padding:1.6rem 0 0.5rem">
    <div class="container">
      <p class="eyebrow">The tool</p>
      <h1 style="font-size:clamp(1.5rem,3vw,2.1rem);margin-bottom:0.5rem">Visualize marker combinations, and explore them with Claude</h1>
      <p class="lede" style="font-size:1.02rem">
        Select any two markers from the panel. Each cell of the tumor cohort is coloured by which of the
        two it carries. The double-positive population is the AND-gate co-detection for that pair. The
        assistant answers questions about any marker or pair from the study's committed tables.
        <a href="/app" target="_blank" rel="noopener">Open full screen</a>.
      </p>
    </div>
  </section>

  <section class="block" style="padding-top:0">
    <div class="container">
      <iframe class="embed" src="/app" title="Explore with Claude" loading="eager" style="height:calc(100vh - 190px);min-height:680px"></iframe>
    </div>
  </section>
</Base>
