---
import Base from '../layouts/Base.astro';
const title = 'Explore with Claude — Dual-marker discovery';
const description = 'TODO: browse the candidate marker pairs and ask a grounded Claude assistant about any marker, pair, or gate. Answers come from the study\'s committed tables.';
---
<Base title={title} description={description} page="explore">
  <section class="hero" style="padding-bottom:0.6rem">
    <div class="container">
      <p class="eyebrow">The tool</p>
      <h1>Explore the pairs, and ask about what you see</h1>
      <p class="lede">
        TODO: the pitch. Pick a pair, and ask. The assistant answers from the study's committed
        tables using tools over the markers, the pairs, and the gate scores, so it can only tell you
        what the data says. It is powered by Claude and is access-controlled. For the full-screen
        experience, <a href="/app" target="_blank" rel="noopener">open it in a new tab</a>.
      </p>
      <div class="btnrow">
        <a class="btn primary" href="/app" target="_blank" rel="noopener">Open in a new tab &rarr;</a>
      </div>
      <div class="todo">
        <p><b>TODO.</b> Tell the reader what to look at and what to ask. The satmut version worked
        because it pointed at one specific element and two specific bases rather than saying
        "explore". Name a pair and name a question.</p>
      </div>
    </div>
  </section>
  <section class="block">
    <div class="container">
      <iframe class="embed" src="/app" title="Explore with Claude" loading="lazy" style="height:90vh"></iframe>
    </div>
  </section>
</Base>
